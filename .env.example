# ── Copy this to .env and fill in your values ──

# Flask secret keys — change both to random strings in production
SECRET_KEY=your-super-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# MySQL connection string
# Local:  mysql+pymysql://root:yourpassword@localhost:3306/classflow
# Render: mysql+pymysql://user:pass@host/classflow  (from Render dashboard)
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/classflow

# Set to 'development' to allow password-less demo login
FLASK_ENV=development
